# Docker environment variables template
# Copy this file to .env and update values as needed

# PostgreSQL Configuration
POSTGRES_DB=quotedb
POSTGRES_USER=quoteuser
POSTGRES_PASSWORD=quotepass

# Application Configuration
SPRING_PROFILES_ACTIVE=docker
KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/quote
KEYCLOAK_CLIENT_ID=quote-api

# Port Mappings (optional - can override in docker-compose.override.yml)
# POSTGRES_PORT=5432
# APP_PORT=8080
