    {
      "name": "get access token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Extract access_token from a successful JSON response and store it in the active environment variable `token`",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "    let json;",
              "    try {",
              "        json = pm.response.json();",
              "    } catch (e) {",
              "        pm.test(\"Response is valid JSON\", function () {",
              "            pm.expect.fail(\"Response body is not valid JSON: \" + e.message);",
              "        });",
              "        json = null;",
              "    }",
              "",
              "    if (json) {",
              "        pm.test(\"Response contains access_token\", function () {",
              "            pm.expect(json).to.have.property(\"access_token\");",
              "            pm.expect(json.access_token).to.be.a(\"string\").and.to.not.be.empty;",
              "        });",
              "",
              "        if (typeof json.access_token === \"string\" && json.access_token.length > 0) {",
              "            pm.environment.set(\"token\", json.access_token);",
              "        }",
              "    }",
              "}",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
