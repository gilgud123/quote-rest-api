    {
      "name": "get author",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Sanitize Bearer token to avoid invalid header characters (newlines/quotes/Bearer prefix)",
              "let t = pm.variables.get('token');",
              "if (t !== undefined && t !== null) {",
              "  t = String(t);",
              "  // Trim whitespace including newlines",
              "  t = t.trim();",
              "  // Remove surrounding quotes (single or double)",
              "  t = t.replace(/^['\"]+|['\"]+$/g, '');",
              "  // Remove leading \"Bearer \" prefix if present",
              "  t = t.replace(/^Bearer\\s+/i, '');",
              "  // Remove any remaining CR/LF that could break headers",
              "  t = t.replace(/[\\r\\n]+/g, '');",
              "",
              "  // Set back into the active environment if available, else local",
              "  if (pm.environment && pm.environment.get('token') !== undefined) {",
              "    pm.environment.set('token', t);",
              "  } else {",
              "    pm.variables.set('token', t);",
              "  }",
              "}",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
